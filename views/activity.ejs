<%- include('partials/head') %>
<body><%- include('partials/nav') %><main>
<div class="top"><span class="eyebrow">Agent Activity Module</span><h1><%= editActivity ? 'Edit Daily Activity' : 'Activity Input Page' %></h1></div>
<%- include('partials/flash') %>
<section class="panel">
  <form method="POST" action="<%= editActivity ? '/activity/' + editActivity.id + '/update' : '/activity' %>" class="form-grid">
    <div><label>Date</label><input type="date" name="activity_date" value="<%= editActivity ? editActivity.activity_date : '' %>" required></div>
    <div><label>Sales Count</label><input type="number" name="sales_count" min="0" value="<%= editActivity ? editActivity.sales_count : '' %>" required></div>
    <div><label>Customers Contacted</label><input type="number" name="customer_count" min="0" value="<%= editActivity ? editActivity.customer_count : '' %>" required></div>
    <div><label>Follow-ups Completed</label><input type="number" name="followups_count" min="0" value="<%= editActivity ? editActivity.followups_count : '0' %>" required></div>
    <div><label>Hours Worked</label><input type="number" step="0.5" name="hours_worked" min="0" value="<%= editActivity ? editActivity.hours_worked : '' %>" required></div>
    <div><label>Mood Level</label><select name="mood_level" required><% [5,4,3,2,1].forEach(v=>{ %><option value="<%= v %>" <%= editActivity && editActivity.mood_level==v ? 'selected' : '' %>><%= v %> - <%= ['','Very Low','Low','Average','Good','Excellent'][v] %></option><% }) %></select></div>
    <div><label>Commitment Level</label><select name="commitment_level" required><% [5,4,3,2,1].forEach(v=>{ %><option value="<%= v %>" <%= editActivity && editActivity.commitment_level==v ? 'selected' : '' %>><%= v %> - <%= ['','Very Low','Low','Moderate','Strong','Very Strong'][v] %></option><% }) %></select></div>
    <div><label>Schedule Preference</label><select name="schedule_preference" required><% ['Morning','Afternoon','Evening','Night','Weekend'].forEach(s=>{ %><option value="<%= s %>" <%= editActivity && editActivity.schedule_preference==s ? 'selected' : '' %>><%= s %></option><% }) %></select></div>
    <div class="full"><label>Customer Update</label><input name="customer_update" value="<%= editActivity ? (editActivity.customer_update || editActivity.notes || '') : '' %>"></div>
    <button type="submit"><%= editActivity ? 'Update Activity & Recalculate' : 'Save Activity & Update Analytics' %></button>
    <% if(editActivity){ %><a class="btn muted" href="/activity">Cancel Edit</a><% } %>
  </form>
</section>
<h2>Recent Activity Records</h2>
<table><tr><th>Date</th><th>Sales</th><th>Customers</th><th>Follow-ups</th><th>Hours</th><th>Mood</th><th>Commitment</th><th>Schedule</th><th>Action</th></tr><% activities.forEach(a=>{ %><tr><td><%= a.activity_date %></td><td><%= a.sales_count %></td><td><%= a.customer_count %></td><td><%= a.followups_count || 0 %></td><td><%= a.hours_worked %></td><td><%= a.mood_level %>/5</td><td><%= a.commitment_level || 3 %>/5</td><td><%= a.schedule_preference || 'Evening' %></td><td class="actions"><a class="btn small" href="/activity/<%= a.id %>/edit">Edit</a><form method="POST" action="/activity/<%= a.id %>/delete"><button class="small danger">Delete</button></form></td></tr><% }) %></table>
</main></body></html>
