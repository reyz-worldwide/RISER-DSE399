<%- include('partials/head') %>
<body><%- include('partials/nav') %><main>
<div class="top"><span class="eyebrow">Admin & Management Module</span><h1>Manage Users & Roles</h1></div>
<%- include('partials/flash') %>
<section class="panel"><h2>Create New User</h2><form method="POST" action="/admin/users" class="form-grid"><div><label>Name</label><input name="name" required></div><div><label>Email</label><input type="email" name="email" required></div><div><label>Password</label><input type="password" name="password" minlength="8" required></div><div><label>Role</label><select name="role"><option value="agent">agent</option><option value="manager">manager</option><option value="admin">admin</option></select></div><div><label>Team</label><input name="team" value="Alpha Growth Team"></div><div><label>Weekly Goal</label><input type="number" name="weekly_goal" value="50" min="0"></div><div><label>Monthly Target</label><input type="number" name="monthly_target" value="200" min="0"></div><div><label>Avatar URL</label><input name="avatar_url" placeholder="/img/agent-avatar.svg"></div><button type="submit">Create User</button></form></section>
<h2>Existing Users</h2>
<table><tr><th>User</th><th>Email</th><th>Team</th><th>Role</th><th>Status</th><th>Weekly</th><th>Monthly</th><th>Avatar</th><th>Update</th></tr><% users.forEach(u=>{ const avatar = u.avatar_url || (u.role==='manager'?'/img/manager-avatar.svg':(u.role==='admin'?'/img/admin-avatar.svg':'/img/agent-avatar.svg')); %><tr><td><div class="profile-mini"><img class="profile-avatar" src="<%= avatar %>" alt="avatar"><strong><%= u.name %></strong></div></td><td><%= u.email %></td><td><form method="POST" action="/admin/users/<%= u.id %>/role" class="table-form"><input name="team" value="<%= u.team %>"></td><td><select name="role"><% ['agent','manager','admin'].forEach(role=>{ %><option value="<%= role %>" <%= u.role===role ? 'selected' : '' %>><%= role %></option><% }) %></select></td><td><select name="status"><option value="active" <%= u.status==='active' ? 'selected' : '' %>>active</option><option value="inactive" <%= u.status==='inactive' ? 'selected' : '' %>>inactive</option></select></td><td><input type="number" name="weekly_goal" value="<%= u.weekly_goal || 0 %>" min="0"></td><td><input type="number" name="monthly_target" value="<%= u.monthly_target || 0 %>" min="0"></td><td><input name="avatar_url" value="<%= avatar %>"></td><td><button class="small">Save</button></form></td></tr><% }) %></table>
<section class="panel"><h2>Audit Logs</h2><table><tr><th>Time</th><th>User</th><th>Action</th><th>Details</th></tr><% logs.forEach(l=>{ %><tr><td><%= l.created_at %></td><td><%= l.name || 'System' %></td><td><%= l.action %></td><td><%= l.details %></td></tr><% }) %></table></section>
</main></body></html>
