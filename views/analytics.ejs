<%- include('partials/head') %>
<body><%- include('partials/nav') %><main>
<% if (mode === 'team') { %>
<div class="top"><span class="eyebrow">Manager / Admin Analytics</span><h1>Team Analytics Dashboard</h1></div>
<div class="grid kpi"><div class="card"><h3>Team Score</h3><b><%= overview.summary.teamScore %></b></div><div class="card"><h3>Total Sales</h3><b><%= overview.summary.totalSales %></b></div><div class="card"><h3>Customers</h3><b><%= overview.summary.totalCustomers %></b></div><div class="card"><h3>Follow-ups</h3><b><%= overview.summary.totalFollowups %></b></div></div>
<section class="panel"><h2>Agent Score Comparison</h2><canvas id="teamChart" height="105"></canvas></section>
<section class="panel"><h2>Team KPI Heatmap</h2><table><tr><th>Agent</th><th>Total</th><th>Growth</th><th>Consistency</th><th>Engagement</th><th>Leadership</th></tr><% overview.leaderboard.forEach(a=>{ %><tr><td><%= a.name %></td><td><span class="heat h<%= Math.floor(a.totalScore/20) %>"><%= a.totalScore %></span></td><td><span class="heat h<%= Math.floor(a.growth/20) %>"><%= a.growth %></span></td><td><span class="heat h<%= Math.floor(a.consistency/20) %>"><%= a.consistency %></span></td><td><span class="heat h<%= Math.floor(a.engagement/20) %>"><%= a.engagement %></span></td><td><span class="heat h<%= Math.floor(a.leadership/20) %>"><%= a.leadership %></span></td></tr><% }) %></table></section>
<script>const labels=<%- JSON.stringify(overview.leaderboard.map(a=>a.name)) %>;const scores=<%- JSON.stringify(overview.leaderboard.map(a=>a.totalScore)) %>;const consistency=<%- JSON.stringify(overview.leaderboard.map(a=>a.consistency)) %>;const engagement=<%- JSON.stringify(overview.leaderboard.map(a=>a.engagement)) %>;new Chart(document.getElementById('teamChart'),{type:'bar',data:{labels,datasets:[{label:'Total Score',data:scores},{label:'Consistency',data:consistency},{label:'Engagement',data:engagement}]},options:{responsive:true,plugins:{legend:{position:'bottom'}}}});</script>
<% } else { %>
<div class="top"><span class="eyebrow">Agent Analytics</span><h1>Analytics Dashboard</h1></div>
<div class="grid four"><div class="card"><h3>Growth Score</h3><b><%= summary.growth %></b></div><div class="card"><h3>Consistency Score</h3><b><%= summary.consistency %></b></div><div class="card"><h3>Engagement Index</h3><b><%= summary.engagement %></b></div><div class="card"><h3>Leadership</h3><b><%= summary.leadership %></b></div></div>
<section class="panel"><h2>Weekly / Monthly Comparison</h2><canvas id="activityChart" height="110"></canvas></section>
<div class="grid two"><section class="panel"><h2>Conversion & Commitment</h2><p><strong>Conversion Rate:</strong> <%= summary.conversionRate %>%</p><p><strong>Average Commitment:</strong> <%= summary.avgCommitment %>/5</p><p><strong>Average Mood:</strong> <%= summary.avgMood %>/5</p><p><strong>Total Hours:</strong> <%= summary.totalHours %></p></section><section class="panel"><h2>Badges</h2><div class="badges"><% summary.badges.forEach(b=>{ %><span><%= b %></span><% }) %></div></section></div>
<script>const labels=<%- JSON.stringify(activities.map(a=>a.activity_date)) %>;const sales=<%- JSON.stringify(activities.map(a=>a.sales_count)) %>;const customers=<%- JSON.stringify(activities.map(a=>a.customer_count)) %>;const followups=<%- JSON.stringify(activities.map(a=>a.followups_count || 0)) %>;new Chart(document.getElementById('activityChart'),{type:'line',data:{labels,datasets:[{label:'Sales',data:sales,tension:.35},{label:'Customers',data:customers,tension:.35},{label:'Follow-ups',data:followups,tension:.35}]},options:{responsive:true,plugins:{legend:{position:'bottom'}}}});</script>
<% } %>
</main></body></html>
