<%- include('partials/head') %>
<body><%- include('partials/nav') %><main>
<div class="top"><span class="eyebrow">Manager Reporting Module</span><h1>Manager Analytics & Reports</h1></div>
<%- include('partials/flash') %>
<section class="panel report-panel"><form method="POST" action="/manager/reports" class="inline-form"><input name="period" value="May 2026"><button>Generate Appraisal Report</button><button type="button" onclick="window.print()" class="btn muted">Print / Save PDF</button></form></section>
<div class="grid kpi"><div class="card"><h3>Average Team Score</h3><b><%= overview.summary.teamScore %></b></div><div class="card"><h3>Total Sales</h3><b><%= overview.summary.totalSales %></b></div><div class="card"><h3>Total Customers</h3><b><%= overview.summary.totalCustomers %></b></div><div class="card"><h3>Support Needed</h3><b><%= overview.summary.needsSupportCount %></b></div></div>
<% if(currentUser.role === 'manager'){ %><h2>Manager AI Recommendations</h2><div class="recommendations"><% recommendations.forEach(r=>{ %><div class="rec priority-<%= r.priority.toLowerCase() %>"><span><%= r.priority %></span><%= r.task %><small><%= r.reason %></small></div><% }) %></div><% } %>
<h2>Top Performer Recognition</h2><section class="panel"><% if(overview.summary.topPerformer){ %><div class="profile-mini"><img class="profile-avatar large" src="<%= overview.summary.topPerformer.avatar_url || '/img/agent-avatar.svg' %>" alt="Top performer"><div><h3><%= overview.summary.topPerformer.name %></h3><p>Score <strong><%= overview.summary.topPerformer.totalScore %></strong></p></div></div><% } else { %><div class="empty">No agent data available.</div><% } %></section>
<h2>Team Performance Summary</h2>
<table><tr><th>Rank</th><th>Agent</th><th>Score</th><th>Sales</th><th>Customers</th><th>Follow-ups</th><th>Active Days</th><th>Badge</th></tr><% leaderboard.forEach(row=>{ %><tr><td>#<%= row.position %></td><td><%= row.name %></td><td><%= row.totalScore %></td><td><%= row.totalSales %></td><td><%= row.totalCustomers %></td><td><%= row.totalFollowups %></td><td><%= row.activeDays %></td><td><%= row.badges[0] %></td></tr><% }) %></table>
<h2>Generated Reports</h2><% if(!reports.length){ %><div class="empty">No report generated yet.</div><% } %><% reports.forEach(r=>{ %><div class="rec report"><span><%= r.period %></span><small>Generated by <%= r.manager_name %> on <%= r.created_at %></small><pre><%= r.summary %></pre></div><% }) %>
</main></body></html>
